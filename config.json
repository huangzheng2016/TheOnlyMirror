{
  "port":8080,
  "tls":false,
  "tls_redirect":false,
  "crt":"",
  "key":"",
  "host_aliases":{
    "ghcr":"ghcr.io",
    "k8s":"registry.k8s.io",
    "k8s-gcr":"k8s.gcr.io",
    "gh":"github.com",
    "api-gh":"api.github.com",
    "assets-ghc":"assets.githubusercontent.com",
    "media-ghc":"media.githubusercontent.com",
    "obj-origin-ghc":"objects-origin.githubusercontent.com",
    "obj-ghc":"objects.githubusercontent.com",
    "raw-ghc":"raw.githubusercontent.com",
    "gist-ghc":"gist.githubusercontent.com",
    "cl-gh":"codeload.github.com",
    "release-ghc":"release-assets.githubusercontent.com",
    "user-img-ghc":"user-images.githubusercontent.com",
    "secured-user-img-ghc":"secured-user-images.githubusercontent.com",
    "private-user-img-ghc":"private-user-images.githubusercontent.com",
    "avatars-ghc":"avatars.githubusercontent.com",
    "camo-ghc":"camo.githubusercontent.com"
  },
  "source_templates":{
    "runtime_production":{
      "template":true,
      "base_name":"{target}_production",
      "targets":["docker","buildkit","containerd","containers"],
      "priority":3,
      "ua":"{target}",
      "path":"/registry-v2",
      "mirror":"https://production.cloudflare.docker.com"
    },
    "runtime_auth":{
      "template":true,
      "base_name":"{target}_auth",
      "targets":["docker","buildkit","containerd","containers"],
      "priority":2,
      "ua":"{target}",
      "path":"/token",
      "mirror":"https://auth.docker.io"
    },
    "runtime_registry":{
      "template":true,
      "base_name":"{target}_registry",
      "targets":["docker","buildkit","containerd","containers"],
      "priority":1,
      "ua":"{target}",
      "replaces":[
        {
          "type":"header",
          "header":"www-authenticate",
          "src":"https://",
          "dst":"<TLS_SCHEME>"
        },
        {
          "type":"header",
          "header":"www-authenticate",
          "src":"auth.docker.io",
          "dst":"<HOST>"
        },
        {
          "type":"header",
          "header":"location",
          "src":"https://",
          "dst":"<TLS_SCHEME>"
        },
        {
          "type":"header",
          "header":"location",
          "src":"production.cloudflare.docker.com",
          "dst":"<HOST>"
        }
      ],
      "mirror":"https://registry-1.docker.io"
    }
  },
  "sources":{
    "copr":{
      "path":"/results",
      "mirror":"https://download.copr.fedorainfracloud.org"
    },
    "chrome-linux":{
      "path":"/linux/chrome",
      "mirror":"https://dl.google.com"
    },
    "ubuntu":{
      "path":"/ubuntu",
      "mirror":"http://archive.ubuntu.com"
    },
    "debian":{
      "path":"/debian",
      "mirror":"https://deb.debian.org"
    },
    "centos":{
      "path":"/centos",
      "mirror":"http://mirror.centos.org"
    },
    "epel-archive":{
      "path":"/pub/archive",
      "mirror":"https://archives.fedoraproject.org"
    },
    "epel":{
      "path":"/pub/epel",
      "mirror":"https://dl.fedoraproject.org"
    },
    "jdoss":{
      "path":"/results/jdoss",
      "mirror":"https://download.copr.fedorainfracloud.org"
    },
    "kali":{
      "path":"/kali",
      "mirror":"https://http.kali.org"
    },
    "alpine":{
      "path":"/alpine",
      "mirror":"https://dl-cdn.alpinelinux.org"
    },
    "github":{
      "ua":"git",
      "mirror":"https://github.com"
    },
    "golang":{
      "path":"/go",
      "mirror":"https://dl.google.com"
    },
    "docker-dl-linux":{
      "path":"/linux",
      "mirror":"https://download.docker.com"
    },
    "docker-dl-mac":{
      "path":"/mac",
      "mirror":"https://download.docker.com"
    },
    "docker-dl-win":{
      "path":"/win",
      "mirror":"https://download.docker.com"
    },
    "pypi_package":{
      "priority":2,
      "ua":"pip",
      "path":"/packages",
      "mirror":"https://files.pythonhosted.org"
    },
    "pypi_web":{
      "priority":1,
      "ua":"pip",
      "replaces":[
        {
          "src":"https://files.pythonhosted.org",
          "dst":""
        }
      ],
      "prefix":"/simple",
      "mirror":"https://pypi.org"
    },
    "npm":{
      "ua":"npm",
      "replaces":[
        {
          "src":"https://",
          "dst":"<TLS_SCHEME>"
        },
        {
          "src":"registry.npmjs.org",
          "dst":"<HOST>"
        }
      ],
      "mirror":"https://registry.npmjs.org"
    },
    "go":{
      "ua":"Go-http-client",
      "mirror":"https://proxy.golang.org"
    }
  },
  "proxy":[
    "https://ghcr.io",
    "https://registry.k8s.io",
    "https://k8s.gcr.io",
    "https://assets.githubusercontent.com",
    "https://media.githubusercontent.com",
    "https://objects-origin.githubusercontent.com",
    "https://raw.githubusercontent.com",
    "https://gist.githubusercontent.com",
    "https://gist.github.com",
    "https://objects.githubusercontent.com",
    "https://codeload.github.com",
    "https://api.github.com",
    "https://release-assets.githubusercontent.com",
    "https://user-images.githubusercontent.com",
    "https://secured-user-images.githubusercontent.com",
    "https://private-user-images.githubusercontent.com",
    "https://avatars.githubusercontent.com",
    "https://camo.githubusercontent.com",
    "https://github.com",
    "https://copr.fedorainfracloud.org",
    "https://cdn.jsdelivr.net",
    "https://archive.debian.org",
    "https://downloads.openwrt.org",
    "https://mainnet.infura.io",
    "https://mikanani.me"
  ]
}
